<?xml version="1.0" encoding="UTF-8"?>
<!--
  Base Camp Outlook Add-in - Manifest

  Hosted at: https://sherpa-amc.github.io/basecamp-outlook-addin
  (GitHub Pages serves files from https://github.com/Sherpa-amc/basecamp-outlook-addin)

  All URLs below point to that hosting. If you fork this repo to a different
  org/user, do a find-and-replace of "sherpa-amc.github.io/basecamp-outlook-addin"
  to your own GitHub Pages URL.
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- Generate a new GUID at https://www.guidgen.com when forking -->
  <Id>4c1f8a3e-2b6d-4e0a-9c7f-8d5b3e0e1a01</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Sherpa Asset Management</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Base Camp"/>
  <Description DefaultValue="Save email PDF attachments to fund folders on the shared drive."/>
  <IconUrl DefaultValue="https://sherpa-amc.github.io/basecamp-outlook-addin/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://sherpa-amc.github.io/basecamp-outlook-addin/assets/icon-128.png"/>
  <SupportUrl DefaultValue="https://sherpa-amc.github.io/basecamp-outlook-addin/"/>

  <!-- Domains the add-in is allowed to load resources from. Localhost is
       implicitly trusted. -->
  <AppDomains>
    <AppDomain>https://localhost:8765</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://sherpa-amc.github.io/basecamp-outlook-addin/taskpane.html"/>
        <RequestedHeight>500</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <!-- Modern manifest extensions: ribbon button, command surfaces, etc. -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.5">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="commandsFile.url"/>

          <!-- Ribbon button shown when reading an email -->
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="groupLabel"/>
                <Control xsi:type="Button" id="msgReadOpenPaneButton">
                  <Label resid="paneButton.label"/>
                  <Supertip>
                    <Title resid="paneButton.title"/>
                    <Description resid="paneButton.tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon.16"/>
                    <bt:Image size="32" resid="icon.32"/>
                    <bt:Image size="80" resid="icon.80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="taskpane.url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="icon.16" DefaultValue="https://sherpa-amc.github.io/basecamp-outlook-addin/assets/icon-16.png"/>
        <bt:Image id="icon.32" DefaultValue="https://sherpa-amc.github.io/basecamp-outlook-addin/assets/icon-32.png"/>
        <bt:Image id="icon.80" DefaultValue="https://sherpa-amc.github.io/basecamp-outlook-addin/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="commandsFile.url" DefaultValue="https://sherpa-amc.github.io/basecamp-outlook-addin/commands.html"/>
        <bt:Url id="taskpane.url" DefaultValue="https://sherpa-amc.github.io/basecamp-outlook-addin/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="groupLabel" DefaultValue="Base Camp"/>
        <bt:String id="paneButton.label" DefaultValue="Save to Fund"/>
        <bt:String id="paneButton.title" DefaultValue="Save to Fund Folder"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="paneButton.tooltip" DefaultValue="Save the email's PDF attachments to the matching fund's folder on the shared drive."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
