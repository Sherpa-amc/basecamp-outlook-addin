<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
           xsi:type="MailApp">
  <Id>a8fdd775-5bd4-43d9-b693-52686fa08a23</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Sherpa Test V3</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Hello Sherpa Test V3"/>
  <Description DefaultValue="Test V3 - V2 plus AppDomains and ReadWriteMailbox."/>
  <IconUrl DefaultValue="https://sherpa-amc.github.io/basecamp-outlook-addin/test/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://sherpa-amc.github.io/basecamp-outlook-addin/test/icon-128.png"/>
  <SupportUrl DefaultValue="https://sherpa-amc.github.io/basecamp-outlook-addin/test/"/>
  <AppDomains>
    <AppDomain>https://localhost:8765</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5"/>
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://sherpa-amc.github.io/basecamp-outlook-addin/test/taskpane.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadWriteMailbox</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.5">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="msgReadOpenPaneButton">
                  <Label resid="TaskpaneButton.Label"/>
                  <Supertip>
                    <Title resid="TaskpaneButton.Label"/>
                    <Description resid="TaskpaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://sherpa-amc.github.io/basecamp-outlook-addin/test/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://sherpa-amc.github.io/basecamp-outlook-addin/test/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://sherpa-amc.github.io/basecamp-outlook-addin/test/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://sherpa-amc.github.io/basecamp-outlook-addin/test/commands.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://sherpa-amc.github.io/basecamp-outlook-addin/test/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Sherpa Test"/>
        <bt:String id="TaskpaneButton.Label" DefaultValue="Hello V3"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Test V3 with AppDomains and ReadWriteMailbox."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
